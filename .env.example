# Server Configuration
PORT=8080
ENV=development

# Database Configuration (Supabase)
# Get these from: https://app.supabase.com/project/_/settings/database
DB_HOST=db.xxxxxxxx.supabase.co
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-supabase-db-password
DB_NAME=postgres
DB_SSLMODE=require

# For Supabase connection pooler (recommended for production):
# DB_HOST=aws-0-region.pooler.supabase.com
# DB_PORT=6543
# DB_SSLMODE=require

# JWT Configuration
# Note: Supabase has its own JWT, but we use separate app JWT for this API
JWT_SECRET=super-secret-jwt-key-change-this-in-production-abc123xyz789
JWT_EXPIRATION=24

# Supabase Configuration (optional - for Supabase Auth integration)
SUPABASE_URL=https://xxxxxxx.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# Payment Gateway Configuration (Midtrans)
# Get your keys from: https://dashboard.midtrans.com/
MIDTRANS_SERVER_KEY=your-midtrans-server-key
MIDTRANS_CLIENT_KEY=your-midtrans-client-key

# Email Configuration (Gmail API)
# Set EMAIL_ENABLED=true when you add your Gmail credentials
EMAIL_ENABLED=false
GMAIL_API_KEY=your-gmail-api-key
GMAIL_SERVICE_ACCOUNT_JSON=
SMTP_FROM_EMAIL=noreply@rentalcar.com
EMAIL_FROM_NAME=Rental Car Service
