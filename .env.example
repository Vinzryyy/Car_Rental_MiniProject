# Server Configuration
PORT=8080
ENV=development

# Database Configuration (PostgreSQL/Supabase)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=rental_car
DB_SSLMODE=disable

# For Supabase connection pooler:
# DB_HOST=aws-0-region.pooler.supabase.com
# DB_PORT=6543
# DB_SSLMODE=require

# JWT Configuration
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRATION=24

# Supabase Configuration (optional, for additional features)
SUPABASE_URL=
SUPABASE_KEY=

# Payment Gateway Configuration (Midtrans)
MIDTRANS_SERVER_KEY=your-midtrans-server-key
MIDTRANS_CLIENT_KEY=your-midtrans-client-key
# Set to true for production environment
# MIDTRANS_IS_PRODUCTION=false

# Email Configuration (Gmail API)
EMAIL_ENABLED=false
GMAIL_API_KEY=your-gmail-api-key
GMAIL_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
SMTP_FROM_EMAIL=noreply@rentalcar.com
EMAIL_FROM_NAME=Rental Car Service
