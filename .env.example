# Server Configuration
SERVER_PORT=8080
SERVER_ENV=development

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=car_rental
DB_SSLMODE=disable

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRATION=24 # in hours

# Xendit Configuration (Payment Gateway)
XENDIT_SECRET_KEY=xnd_development_...
XENDIT_PUBLIC_KEY=xnd_public_...

# Gmail API Configuration (Email Service)
# Use either Service Account JSON or API Key
GMAIL_SERVICE_ACCOUNT_JSON=
GMAIL_API_KEY=
EMAIL_FROM=noreply@rentalcar.com
EMAIL_FROM_NAME="Rental Car Service"

# Cloudinary Configuration (Image Hosting - 3rd Party API)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Railway Specific (for reference)
# DATABASE_URL will be automatically provided by Railway
