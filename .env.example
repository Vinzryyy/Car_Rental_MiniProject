# Server Configuration
SERVER_PORT=8080
SERVER_ENV=development

# Database Configuration (Standard)
# If using DATABASE_URL (Standard for Railway/Supabase), other DB_ fields can be ignored
DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=disable

# Database Configuration (Manual - if DATABASE_URL is not used)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=car_rental
DB_SSLMODE=disable

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRATION=24 # in hours

# Xendit Configuration (Payment Gateway)
XENDIT_SECRET_KEY=xnd_development_...
XENDIT_PUBLIC_KEY=xnd_public_...

# Email Configuration (Resend API recommended)
EMAIL_ENABLED=false
RESEND_API_KEY=re_123456789
SMTP_FROM_EMAIL=onboarding@resend.dev
EMAIL_FROM_NAME="Rental Car Service"

# Legacy Gmail API Configuration (Alternative)
GMAIL_SERVICE_ACCOUNT_JSON=
GMAIL_API_KEY=

# Cloudinary Configuration (Image Hosting - 3rd Party API)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
